<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for night mode. -->
    <!-- We force light theme components to match the app's specific light UI design -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorSecondary">@color/accent_yellow</item>
        <item name="android:windowBackground">@color/bg_light</item>

        <!-- Dialog Theme -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
    </style>
</resources>
